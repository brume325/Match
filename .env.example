# MATCH MOOV — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs.

# ── Base de données MariaDB ────────────────────────────────────────────
# En Docker : DB_HOST=db  (nom du service Docker Compose)
# En local  : DB_HOST=127.0.0.1
DB_HOST=db
DB_PORT=3306
DB_NAME=bd_matchmoove
DB_USER=matchmoov
DB_PASS=secret
DB_ROOT_PASS=rootsecret

# ── Application ───────────────────────────────────────────────────────
# URL de base utilisée pour les liens dans les e-mails (vérification, reset)
APP_URL=http://localhost:8080
APP_ENV=local

# ── Cloudflare Tunnel (optionnel) ─────────────────────────────────────
# Laisser vide → Quick Tunnel temporaire (URL générée automatiquement)
# Renseigner un token → tunnel permanent (créer sur dash.cloudflare.com)
CLOUDFLARE_TOKEN=

# ── Mail (optionnel, utilisé par mail() PHP) ──────────────────────────
# En développement Docker, les e-mails sont envoyés vers la sortie PHP
# En production : configurer un relais SMTP (Mailgun, SendGrid, etc.)
MAIL_FROM=no-reply@matchmoov.fr
